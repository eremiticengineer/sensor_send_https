menu "SensorSend Configuration"

config SENSOR_SEND_USER_AGENT
    string "UserAgent Name"
    default "esp-idf/1.0 esp32"
    help
      Enter the name of your UserAgent

config SENSOR_SEND_WEB_SERVER
    string "The domain name of the web server hosting the sensor data"
    default "www.server.com"
    help
      Enter the domain name of the web server hosting the sensor data

config SENSOR_SEND_WEB_SERVER_HTTPS_PORT
    string "The HTTPS port of the web server hosting the sensor data"
    default "443"
    help
      Enter the HTTPS port of the web server hosting the sensor data

config SENSOR_SEND_WEB_SERVER_HTTPS_POST_PATH
    string "The full HTTPS POST url on the web server hosting the sensor data"
    default "www.server.com/esp32/sensor.php"
    help
      Enter the full HTTPS POST url on the web server hosting the sensor data

config SENSOR_SEND_WEB_SERVER_HTTPS_POST_API_KEY
    string "The api key for the image upload"
    default ""
    help
      Enter the api key for the image upload

config SENSOR_SEND_OTA_PATH
    string "The url of the ota information file"
    default "https://server.com/ota.json"
    help
      Enter the url of the ota information file

endmenu